{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-spec-first.sh",
            "description": "Bash版：Linux/macOS/MSYS2 用户使用此配置"
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -File .claude/hooks/check-spec-first.ps1",
            "description": "PowerShell版：Windows 原生 PowerShell 用户使用此配置"
          }
        ]
      }
    ]
  }
}
